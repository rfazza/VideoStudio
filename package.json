{
  "name": "zzrco-videostudio",
  "version": "1.0.5",
  "description": "ZZRCO VideoStudio",
  "repository": {},
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@remotion/bundler": "4.0.450",
    "@rspack/core": "1.7.6",
    "@rspack/binding": "1.7.6",
    "@remotion/cli": "4.0.450",
    "@remotion/media-parser": "4.0.450",
    "@remotion/media-utils": "4.0.450",
    "@remotion/player": "4.0.450",
    "@remotion/renderer": "4.0.450",
    "@remotion/studio": "4.0.450",
    "@remotion/studio-server": "4.0.450",
    "@remotion/studio-shared": "4.0.450",
    "@remotion/tailwind-v4": "4.0.450",
    "@remotion/web-renderer": "4.0.450",
    "@remotion/zod-types": "4.0.450",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "remotion": "4.0.450",
    "sucrase": "^3.35.1",
    "tailwindcss": "4.0.0",
    "zod": "^4.3.6",
    "electron-is-dev": "^2.0.0"
  },
  "devDependencies": {
    "@remotion/eslint-config-flat": "4.0.450",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/web": "0.0.166",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "9.19.0",
    "prettier": "3.8.1",
    "typescript": "5.9.3",
    "vite": "^8.0.9",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "wait-on": "^7.2.0",
    "concurrently": "^8.2.2"
  },
  "overrides": {
    "remotion": "4.0.450",
    "@remotion/player": "4.0.450",
    "@remotion/cli": "4.0.450",
    "@remotion/renderer": "4.0.450",
    "@remotion/bundler": "4.0.450",
    "@remotion/media-utils": "4.0.450",
    "@remotion/studio": "4.0.450",
    "@remotion/studio-server": "4.0.450",
    "@remotion/studio-shared": "4.0.450",
    "@remotion/media-parser": "4.0.450",
    "@remotion/web-renderer": "4.0.450",
    "@remotion/zod-types": "4.0.450",
    "@remotion/compositor-win32-x64-msvc": "4.0.450",
    "@remotion/streaming": "4.0.450",
    "@remotion/licensing": "4.0.450"
  },
  "scripts": {
    "dev": "remotion studio",
    "custom-studio": "vite",
    "render-server": "node render-server.js",
    "build": "remotion bundle",
    "build-ui": "vite build",
    "upgrade": "remotion upgrade",
    "lint": "eslint src && tsc",
    "electron-dev": "concurrently \"npm run custom-studio\" \"npm run render-server\" \"wait-on http://localhost:5173 && electron .\"",
    "electron-build": "npx rimraf dist-electron && npm run build-ui && electron-builder",
    "electron-build-mac": "npx rimraf dist-electron && npm run build-ui && electron-builder --mac",
    "postinstall": "electron-builder install-app-deps"
  },
  "main": "electron-main.js",
  "build": {
    "appId": "com.zzrco.videostudio",
    "productName": "ZZRCO VideoStudio",
    "asar": true,
    "directories": {
      "output": "dist-electron"
    },
    "asarUnpack": [
      "**/*.node",
      "**/node_modules/@rspack/binding/**/*"
    ],
    "mac": {
      "category": "public.app-category.video",
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "public/icon.icns"
    },
    "win": {
      "icon": "public/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "VideoStudio Setup.${ext}"
    },
    "nsis": {
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico",
      "uninstallDisplayName": "VideoStudio - By zzrco",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": false
    },
    "extraResources": [
      {
        "from": "node_modules/@rspack/binding",
        "to": "node_modules/@rspack/binding"
      },
      {
        "from": "ffmpeg",
        "to": "ffmpeg",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "render-server.js",
        "to": "render-server.js"
      },
      {
        "from": "src",
        "to": "src"
      },
      {
        "from": "node_modules",
        "to": "node_modules"
      }
    ],
    "files": [
      "dist/**/*",
      "electron-main.js",
      "preload.js",
      "package.json"
    ]


  },
  "sideEffects": [
    "*.css"
  ]
}
